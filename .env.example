# EVEN_TERMINAL_PORT
# What you can do: set the default port when running install.ps1/install.sh.
# What you can't do: this is documentation only — scripts read ~/.config/even-terminal/config.json
#   at runtime. To change port after install, edit config.json and re-run install with --force.
# Format: integer 1024-65535.
# Example: EVEN_TERMINAL_PORT=3456
EVEN_TERMINAL_PORT=3456

# EVEN_TERMINAL_NETWORK_MODE
# What you can do: set the default network mode passed to install.ps1/install.sh.
# What you can't do: changing this file after install has no effect until you re-run install --force.
# Values: auto (default) | tailscale | lan | loopback
# Example: EVEN_TERMINAL_NETWORK_MODE=auto
EVEN_TERMINAL_NETWORK_MODE=auto

# EVEN_TERMINAL_CONFIG_DIR
# What you can do: override the config directory (testing, multi-profile setups).
# What you can't do: service-level overrides need the plist/unit Environment= to be updated.
# Format: absolute path.
# Example (Windows): EVEN_TERMINAL_CONFIG_DIR=C:\Users\you\.config\even-terminal
# Example (POSIX):   EVEN_TERMINAL_CONFIG_DIR=/home/you/.config/even-terminal
EVEN_TERMINAL_CONFIG_DIR=

# EVEN_TERMINAL_TASK_NAME (Windows only)
# What you can do: override the Task Scheduler task name (useful for testing).
# What you can't do: does not affect launchd/systemd unit names on POSIX.
# Format: string without special characters.
# Example: EVEN_TERMINAL_TASK_NAME=EvenTerminalAutostart
EVEN_TERMINAL_TASK_NAME=EvenTerminalAutostart
